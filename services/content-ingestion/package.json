{
  "name": "content-ingestion",
  "version": "1.0.0",
  "description": "Durable Content Ingestion Service for Football Verse",
  "main": "dist/worker.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/worker.ts",
