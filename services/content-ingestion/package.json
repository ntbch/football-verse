    "test": "npm run build && node --test test/*.test.js",
    "replay-failed": "node dist/replay.js",
    "start": "node dist/worker.js"
  },
  "dependencies": {
    "cheerio": "^1.0.0-rc.12",
    "got-scraping": "^4.0.5",
    "node-cron": "^3.0.3",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.6",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.2"
  }
}
