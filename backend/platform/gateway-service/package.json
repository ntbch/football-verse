{
  "name": "realtime-gateway",
  "version": "1.0.0",
  "description": "API Gateway and Realtime WebSocket Server for Football Verse",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:crawler": "ts-node-dev --respawn --transpile-only src/crawler-worker.ts",
    "build": "tsc",
    "test": "npm run build && node --test test/*.test.js",
    "start": "node dist/server.js",
    "start:crawler": "node dist/crawler-worker.js"
  },
  "dependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "cheerio": "^1.0.0-rc.12",
    "express": "^4.19.2",
    "fingerprint-generator": "^2.1.20",
    "got-scraping": "^4.0.5",
    "http-proxy-middleware": "^3.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^3.0.3",
    "playwright": "^1.45.0",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "@types/node-cron": "^3.0.11",
    "socket.io-client": "^4.8.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.2"
  }
}
